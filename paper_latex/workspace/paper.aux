\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Left: Standard MinHash MSE decreases as O(1/k) with k=16 (MSE=0.0140), k=32 (MSE=0.0056), k=64 (MSE=0.0022), k=128 (MSE=0.0011). Right: Rateless MinHash progressive MSE curves for J$\in $\{0.1, 0.3, 0.5, 0.7, 0.9\} showing 55-80\% reduction from 10 to 128 hash values.}}{8}{figure.2}\protected@file@percent }
\newlabel{fig:fig2}{{2}{8}{Left: Standard MinHash MSE decreases as O(1/k) with k=16 (MSE=0.0140), k=32 (MSE=0.0056), k=64 (MSE=0.0022), k=128 (MSE=0.0011). Right: Rateless MinHash progressive MSE curves for J$\in $\{0.1, 0.3, 0.5, 0.7, 0.9\} showing 55-80\% reduction from 10 to 128 hash values}{figure.2}{}}
